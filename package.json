{
  "name": "remember",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "backend:dev": "yarn workspace @remember/backend dev",
    "backend:deploy": "yarn workspace @remember/backend deploy",
    "web:dev": "yarn workspace @remember/web dev",
    "web:build": "yarn workspace @remember/web build",
    "mobile:start": "yarn workspace @remember/mobile start"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "~5.9.3"
  },
  "resolutions": {
    "@types/react": "^19.2.0"
  },
  "overrides": {
    "@types/react": "^19.2.0"
  }
}
